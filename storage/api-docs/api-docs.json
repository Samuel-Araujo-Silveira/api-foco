                ],
                "summary": "Exibir uma reserva específica",
                "operationId": "42f417a78cf996da1053c90767936fc4",
                "parameters": [
                    {
                        "name": "reservation",
                        "in": "path",
                        "description": "ID da reserva",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1001
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Reserva encontrada",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Reservation"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Reserva não encontrada"
                    }
                }
            }
        },
        "/reservations/{id}": {
            "delete": {
                "tags": [
                    "Reservations"
                ],
                "summary": "Remover uma reserva",
                "operationId": "7eb4cb182a79cf2e8697cf93a6bfc0f7",
                "parameters": [
