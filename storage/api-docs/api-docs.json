    "paths": {
        "/reservations": {
            "get": {
                "tags": [
                    "Reservations"
                ],
                "summary": "Listar todas as reservas",
                "operationId": "573c89dfb714acb02c1b2f4826b22f0d",
                "responses": {
                    "200": {
                        "description": "Lista de reservas retornada com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Reservation"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Reservations"
                ],
                "summary": "Criar uma nova reserva",
                "operationId": "dccb73c16710c16c1ee2391ae06b2e09",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id",
                                    "reservation_room_id",
                                    "first_name",
                                    "last_name",
                                    "hotel_id",
                                    "room_id",
                                    "arrival_date",
                                    "departure_date",
                                    "currencycode",
                                    "meal_plan",
                                    "totalprice",
                                    "guest_counts",
                                    "prices"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1001
                                    },
                                    "reservation_room_id": {
                                        "type": "integer",
                                        "example": 2001
                                    },
                                    "first_name": {
                                        "type": "string",
                                        "example": "João"
                                    },
                                    "last_name": {
                                        "type": "string",
                                        "example": "Silva"
                                    },
                                    "hotel_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "room_id": {
                                        "type": "integer",
                                        "example": 101
                                    },
                                    "arrival_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-06-10"
                                    },
                                    "departure_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-06-15"
                                    },
                                    "currencycode": {
                                        "type": "string",
                                        "example": "BRL"
                                    },
                                    "meal_plan": {
                                        "type": "string",
                                        "example": "breakfast"
                                    },
                                    "totalprice": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 1500
                                    },
                                    "guest_counts": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "type",
                                                "count"
                                            ],
                                            "properties": {
                                                "type": {
                                                    "type": "string",
                                                    "example": "adult"
                                                },
                                                "count": {
                                                    "type": "integer",
                                                    "minimum": 1,
                                                    "example": 2
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "prices": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "rate_id",
                                                "date",
                                                "amount"
                                            ],
                                            "properties": {
                                                "rate_id": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "date": {
                                                    "type": "string",
                                                    "format": "date",
                                                    "example": "2024-06-10"
                                                },
                                                "amount": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 300
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Reserva criada com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Reservation"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Quarto não disponível para o período"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
        "/reservations/{reservation}": {
            "get": {
                "tags": [
